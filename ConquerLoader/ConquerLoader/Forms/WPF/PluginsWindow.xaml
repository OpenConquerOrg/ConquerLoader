<Window x:Class="ConquerLoader.Forms.WPF.PluginsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Plugins"
        Width="980"
        Height="680"
        MinWidth="820"
        MinHeight="560"
        Background="#09090D"
        ResizeMode="CanResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner">
    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            NonClientFrameEdges="None"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ConquerLoader;component/Forms/WPF/SharedTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F4F7FC" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#D3D9E3" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#CB4129" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#120E13" />
        <SolidColorBrush x:Key="OutlineBrush" Color="#9EA6B4" />
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Padding" Value="24" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="#808997" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#231719" />
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SecondaryBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SecondaryBorder" Property="Background" Value="#2E1E20" />
                                <Setter TargetName="SecondaryBorder" Property="BorderBrush" Value="#B3834D" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SecondaryBorder" Property="Background" Value="#1A1011" />
                                <Setter TargetName="SecondaryBorder" Property="BorderBrush" Value="#D1A56B" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="SecondaryBorder" Property="BorderBrush" Value="#D1A56B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#1D1416" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChromeBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,-1,0,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChromeBorder" Property="Background" Value="#2C1D1F" />
                                <Setter TargetName="ChromeBorder" Property="BorderBrush" Value="#C58A49" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChromeBorder" Property="Background" Value="#160E10" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Close">
                                <Setter Property="Foreground" Value="#EFB8AA" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Close" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ChromeBorder" Property="Background" Value="#5D1B1E" />
                                <Setter TargetName="ChromeBorder" Property="BorderBrush" Value="#F06A58" />
                                <Setter Property="Foreground" Value="White" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Close" />
                                    <Condition Property="IsPressed" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ChromeBorder" Property="Background" Value="#421113" />
                                <Setter TargetName="ChromeBorder" Property="BorderBrush" Value="#F06A58" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ChromeBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Border Margin="0" Background="#09080B" BorderBrush="#00FFFFFF" BorderThickness="0" CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#170F12" BorderBrush="#6B4C2D" BorderThickness="0,0,0,1" PreviewMouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,8,16,8" PreviewMouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Width="24"
                               Height="24"
                               Margin="0,0,10,0"
                               Source="pack://application:,,,/Resources/ConquerLoaderICON.png"
                               Stretch="Uniform" />
                        <TextBlock x:Name="txtWindowTitleBar" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Text="Plugins" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="btnMinimizeWindow" Click="BtnMinimizeWindow_Click" Content="_" Style="{StaticResource TitleBarButtonStyle}" />
                        <Button x:Name="btnMaxRestoreWindow" Click="BtnMaxRestoreWindow_Click" Content="[]" Style="{StaticResource TitleBarButtonStyle}" />
                        <Button x:Name="btnCloseWindow" Click="BtnCloseWindow_Click" Content="X" Style="{StaticResource TitleBarButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
            <Grid Grid.Row="1" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="txtPluginsHeading" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Text="Plugins" TextWrapping="Wrap" />
                            <TextBlock x:Name="txtPluginsDescription" Margin="0,8,0,0" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Text="Review local plugins, browse the public free catalog and your assigned premium modules, and decide which ones should be installed." TextWrapping="Wrap" />
                            <TextBlock x:Name="txtPluginsHint" Margin="0,12,0,0" FontSize="12" Foreground="{StaticResource PrimaryBrush}" Text="Local plugins come from the Plugins folder. Free remote plugins come from the public catalog, and premium remote plugins come from your license assignments." TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                            <Button x:Name="btnRefresh" Width="120" Margin="0,0,12,0" Click="BtnRefresh_Click" Content="Refresh" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button x:Name="btnClose" Width="110" Click="BtnClose_Click" Content="Close" Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Grid Grid.Row="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="pluginsItems">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemWidth="310" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="292" Margin="0,0,18,18" Padding="20" Background="{StaticResource SurfaceBrush}" BorderBrush="#5A3D25" BorderThickness="1" CornerRadius="20">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Text="{Binding Name}" TextWrapping="Wrap" />
                                            <WrapPanel Grid.Row="1" Margin="0,12,0,0">
                                                <Border Margin="0,0,8,8" Padding="10,4" Background="#24181A" BorderBrush="#8B6340" BorderThickness="1" CornerRadius="999">
                                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Text="{Binding SourceText}" />
                                                </Border>
                                                <Border Margin="0,0,8,8" Padding="10,4" Background="#1A2029" BorderBrush="#66778E" BorderThickness="1" CornerRadius="999">
                                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Text="{Binding TierText}" />
                                                </Border>
                                                <Border Margin="0,0,8,8" Padding="10,4" Background="#1E1517" BorderBrush="#9EA6B4" BorderThickness="1" CornerRadius="999">
                                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Text="{Binding StatusText}" />
                                                </Border>
                                            </WrapPanel>
                                            <TextBlock Grid.Row="2" Margin="0,8,0,0" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Text="{Binding Explanation}" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="3" Margin="0,12,0,0" FontSize="12" Foreground="{StaticResource PrimaryBrush}" Text="{Binding HintText}" TextWrapping="Wrap" />
                                            <WrapPanel Grid.Row="5" Margin="0,18,0,0">
                                                <Button Width="112"
                                                        Margin="0,0,10,10"
                                                        Click="BtnInstall_Click"
                                                        Content="{Binding InstallButtonText}"
                                                        Tag="{Binding}"
                                                        Visibility="{Binding InstallVisibility}"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                                <Button Width="120"
                                                        Margin="0,0,10,10"
                                                        Click="BtnToggleEnabled_Click"
                                                        Content="{Binding ToggleButtonText}"
                                                        Tag="{Binding}"
                                                        Visibility="{Binding ToggleVisibility}"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                                <Button Width="112"
                                                        Margin="0,0,10,10"
                                                        Click="BtnConfigure_Click"
                                                        Content="{Binding ConfigureButtonText}"
                                                        Tag="{Binding}"
                                                        Visibility="{Binding ConfigureVisibility}"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                                <Button Width="112"
                                                        Margin="0,0,10,10"
                                                        Click="BtnRemove_Click"
                                                        Content="{Binding RemoveButtonText}"
                                                        Tag="{Binding}"
                                                        Visibility="{Binding RemoveVisibility}"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Border x:Name="emptyStateCard"
                            Visibility="Collapsed"
                            Padding="28"
                            Background="#120E13"
                            BorderBrush="#5A3D25"
                            BorderThickness="1"
                            CornerRadius="24">
                        <TextBlock x:Name="txtEmptyState"
                                   FontSize="15"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="No plugins are available right now. Add local DLLs to the Plugins folder or wait for public free or assigned remote modules to appear."
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
