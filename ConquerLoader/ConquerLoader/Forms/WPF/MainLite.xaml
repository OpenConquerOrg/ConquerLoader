<Window x:Class="ConquerLoader.Forms.WPF.MainLite"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="ConquerLoader"
        Width="1180"
        Height="800"
        MinWidth="980"
        MinHeight="720"
        Background="#07090E"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen">
    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            NonClientFrameEdges="None"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ConquerLoader;component/Forms/WPF/SharedTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#CB4129" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#A02418" />
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#4A1B15" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#160F12" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#1E1517" />
        <SolidColorBrush x:Key="OutlineBrush" Color="#6B4C2D" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F7EEE4" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#D6BDA1" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#73D995" />
        <SolidColorBrush x:Key="InfoSoftBrush" Color="#241816" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FF8974" />
        <SolidColorBrush x:Key="GoldBrush" Color="#E0B36D" />

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="28" />
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="#5A3D25" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24"
                                      Direction="270"
                                      Opacity="0.36"
                                      ShadowDepth="12"
                                      Color="#040203" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="BodyStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="52" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="#FFF3EA" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PrimaryBorder"
                                BorderBrush="#D7A96A"
                                BorderThickness="1"
                                CornerRadius="16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#D0442B" Offset="0" />
                                    <GradientStop Color="#821914" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border Margin="1"
                                    CornerRadius="15"
                                    BorderBrush="#2AFFE3B8"
                                    BorderThickness="1"
                                    Opacity="0.3">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PrimaryBorder" Property="Background" Value="{StaticResource PrimaryDarkBrush}" />
                                <Setter TargetName="PrimaryBorder" Property="BorderBrush" Value="#F1C78F" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PrimaryBorder" Property="Background" Value="#73110F" />
                                <Setter TargetName="PrimaryBorder" Property="BorderBrush" Value="#F1C78F" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="PrimaryBorder" Property="BorderBrush" Value="#F8D9A9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PrimaryBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LaunchButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Height" Value="66" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#FFF8F1" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F35D3C" Offset="0" />
                        <GradientStop Color="#B22819" Offset="0.55" />
                        <GradientStop Color="#60110D" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="LaunchGlow"
                                    Margin="18,14,18,2"
                                    Background="#44CB4129"
                                    CornerRadius="24"
                                    Opacity="0.9">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="30"
                                                      Direction="270"
                                                      Opacity="0.5"
                                                      ShadowDepth="12"
                                                      Color="#7A1A12" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="LaunchBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#E4B77A"
                                    BorderThickness="1.5"
                                    CornerRadius="20">
                                <Grid>
                                    <Border Margin="2"
                                            BorderBrush="#2BFFE9C5"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Opacity="0.45" />
                                    <Border Height="20"
                                            Margin="10,8,10,0"
                                            VerticalAlignment="Top"
                                            Background="#33FFF3E1"
                                            CornerRadius="10"
                                            Opacity="0.7" />
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="0,-2,0,0" />
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="LaunchGlow" Property="Opacity" Value="1" />
                                <Setter TargetName="LaunchBorder" Property="BorderBrush" Value="#F4CA90" />
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF6A46" Offset="0" />
                                            <GradientStop Color="#C3301D" Offset="0.55" />
                                            <GradientStop Color="#721713" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="LaunchGlow" Property="Opacity" Value="0.4" />
                                <Setter TargetName="LaunchBorder" Property="BorderBrush" Value="#F6D4A3" />
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#D94B2E" Offset="0" />
                                            <GradientStop Color="#931E15" Offset="0.55" />
                                            <GradientStop Color="#4A0D0A" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="LaunchBorder" Property="BorderBrush" Value="#FFE0B36D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="LaunchGlow" Property="Opacity" Value="0.2" />
                                <Setter TargetName="LaunchBorder" Property="BorderBrush" Value="#8A6646" />
                                <Setter Property="Foreground" Value="#DDC7B0" />
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#704339" Offset="0" />
                                            <GradientStop Color="#4E2A25" Offset="0.55" />
                                            <GradientStop Color="#2E1715" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#231719" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SecondaryBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SecondaryBorder" Property="Background" Value="#2E1E20" />
                                <Setter TargetName="SecondaryBorder" Property="BorderBrush" Value="#B3834D" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SecondaryBorder" Property="Background" Value="#1A1011" />
                                <Setter TargetName="SecondaryBorder" Property="BorderBrush" Value="#D1A56B" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="SecondaryBorder" Property="BorderBrush" Value="#D1A56B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SecondaryBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="#7F1D1D" />
            <Setter Property="Background" Value="#2A1317" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Background" Value="#191113" />
            <Setter Property="BorderBrush" Value="#503725" />
        </Style>

        <Style x:Key="ComboToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent">
                            <Path Width="10"
                                  Height="6"
                                  Margin="0,0,16,0"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Fill="{StaticResource TextSecondaryBrush}"
                                  Data="M 0 0 L 10 0 L 5 6 Z" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="16">
                                <Grid>
                                    <ToggleButton ClickMode="Press"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Style="{StaticResource ComboToggleButtonStyle}" />
                                    <ContentPresenter Margin="14,0,42,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" />
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade"
                                   StaysOpen="False">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,8,0,0"
                                        Background="#1A1011"
                                        BorderBrush="{StaticResource OutlineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <ScrollViewer Margin="4"
                                                  SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#B3834D" />
                                <Setter TargetName="ComboBorder" Property="Background" Value="#241816" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#D1A56B" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#D1A56B" />
                                <Setter TargetName="ComboBorder" Property="Background" Value="#241816" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Margin="2"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#3A231F" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#8F301F" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsHighlighted" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemBorder" Property="Background" Value="#B5462C" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border Background="Transparent">
                            <BulletDecorator VerticalAlignment="Center">
                                <BulletDecorator.Bullet>
                                    <Border x:Name="CheckBorder"
                                            Width="22"
                                            Height="22"
                                            Margin="0,0,2,0"
                                            Background="#1D1416"
                                            BorderBrush="{StaticResource OutlineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="7">
                                        <Path x:Name="CheckGlyph"
                                              Width="11"
                                              Height="8"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M 1 4.5 L 4.3 7.5 L 10 1"
                                              Stroke="White"
                                              StrokeThickness="2"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              Visibility="Collapsed" />
                                    </Border>
                                </BulletDecorator.Bullet>
                                <TextBlock Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="{TemplateBinding FontSize}"
                                           Foreground="{TemplateBinding Foreground}"
                                           Text="{TemplateBinding Content}"
                                           TextWrapping="WrapWithOverflow" />
                            </BulletDecorator>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#241816" />
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#B3834D" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#D1A56B" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#8F301F" />
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#E0B36D" />
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="CheckBorder" Property="Background" Value="#B5462C" />
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#F1C78F" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProgressStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Foreground" Value="{StaticResource GoldBrush}" />
            <Setter Property="Background" Value="#2B1B1D" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#1D1416" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChromeBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,-1,0,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChromeBorder" Property="Background" Value="#2C1D1F" />
                                <Setter TargetName="ChromeBorder" Property="BorderBrush" Value="#C58A49" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChromeBorder" Property="Background" Value="#160E10" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Close">
                                <Setter Property="Foreground" Value="#EFB8AA" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Close" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ChromeBorder" Property="Background" Value="#5D1B1E" />
                                <Setter TargetName="ChromeBorder" Property="BorderBrush" Value="#F06A58" />
                                <Setter Property="Foreground" Value="White" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Close" />
                                    <Condition Property="IsPressed" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ChromeBorder" Property="Background" Value="#421113" />
                                <Setter TargetName="ChromeBorder" Property="BorderBrush" Value="#F06A58" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ChromeBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Margin="10"
            Background="#0A090C"
            BorderBrush="#6B4C2D"
            BorderThickness="1"
            CornerRadius="22">
        <Grid>
            <Grid.Background>
                <RadialGradientBrush Center="0.52,0.18" GradientOrigin="0.52,0.18" RadiusX="0.95" RadiusY="0.95">
                    <GradientStop Color="#442115" Offset="0" />
                    <GradientStop Color="#211214" Offset="0.42" />
                    <GradientStop Color="#09090D" Offset="1" />
                </RadialGradientBrush>
            </Grid.Background>

            <Ellipse Width="760"
                     Height="760"
                     Margin="-130,-240,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="#22FF9F45"
                     IsHitTestVisible="False" />
            <Ellipse Width="520"
                     Height="520"
                     Margin="0,-150,-140,0"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Fill="#18D96E42"
                     IsHitTestVisible="False" />
            <Rectangle VerticalAlignment="Bottom"
                       Height="260"
                       IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00FFFFFF" Offset="0" />
                        <GradientStop Color="#D209090D" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="56" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#7A100D10"
                        BorderBrush="#4A2B1D"
                        BorderThickness="0,0,0,1"
                        PreviewMouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="16,8,16,8"
                          PreviewMouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    PreviewMouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                            <Border Width="30"
                                    Height="30"
                                    CornerRadius="14"
                                    Background="#2E1712"
                                    BorderBrush="#8A613A"
                                    BorderThickness="1">
                                <Image Width="22"
                                       Height="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Source="pack://application:,,,/Resources/ConquerLoaderICON.png"
                                       Stretch="Uniform" />
                            </Border>
                            <StackPanel Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        PreviewMouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                                <TextBlock Text="ConquerLoader"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="server launcher"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button x:Name="btnMinimizeWindow"
                                    Click="BtnMinimizeWindow_Click"
                                    Content="&#xE921;"
                                    ToolTip="Minimize"
                                    Style="{StaticResource TitleBarButtonStyle}" />
                            <Button x:Name="btnMaxRestoreWindow"
                                    Click="BtnMaxRestoreWindow_Click"
                                    Content="□"
                                    Style="{StaticResource TitleBarButtonStyle}" />
                            <Button x:Name="btnCloseWindow"
                                    Click="BtnCloseWindow_Click"
                                    Content="&#xE8BB;"
                                    Tag="Close"
                                    ToolTip="Close"
                                    Style="{StaticResource TitleBarButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource CardBorderStyle}"
                        Background="#8C120E10"
                        BorderBrush="#7A5733">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Width="124"
                                Height="124"
                                Background="#22000000"
                                BorderBrush="#B88A4C"
                                BorderThickness="2"
                                CornerRadius="62"
                                VerticalAlignment="Center">
                            <Image Width="98"
                                   Height="98"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Source="pack://application:,,,/Resources/ConquerLoaderICON.png"
                                   Stretch="Uniform" />
                        </Border>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <Border Width="156"
                                    Height="34"
                                    Margin="0,0,0,12"
                                    HorizontalAlignment="Left"
                                    Background="#352113"
                                    BorderBrush="#9C7242"
                                    BorderThickness="1"
                                    CornerRadius="17">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource GoldBrush}"
                                           Text="SERVER PORTAL" />
                            </Border>
                            <TextBlock x:Name="txtWindowTitle"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="txtHeaderDescription"
                                       Margin="0,12,0,0"
                                       MaxWidth="620"
                                       Style="{StaticResource BodyStyle}"
                                       Text="Choose your realm, review the launch panel, and enter the client from one guided launcher." />
                        </StackPanel>

                        <Border Grid.Column="3"
                                Padding="18"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="#281715"
                                BorderBrush="#8A613A"
                                BorderThickness="1"
                                CornerRadius="22">
                            <StackPanel Width="238">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="Selected realm" />
                                <TextBlock x:Name="txtSelectedServer"
                                           Margin="0,6,0,0"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="No server selected"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="txtServerStatusHint"
                                           Margin="0,10,0,0"
                                           Style="{StaticResource BodyStyle}"
                                           Text="The selected server will be checked before launch." />
                                <WrapPanel Margin="0,18,0,0">
                                    <Button x:Name="btnSettingsHeader"
                                            Width="112"
                                            Margin="0,0,10,10"
                                            Click="BtnSettings_Click"
                                            Content="Settings"
                                            Style="{StaticResource GhostButtonStyle}" />
                                    <Button x:Name="lblAbout"
                                            Width="102"
                                            Margin="0,0,0,10"
                                            Click="LblAbout_Click"
                                            Content="About"
                                            Style="{StaticResource GhostButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.02*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="1.18*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource CardBorderStyle}"
                            Background="#8D140F12"
                            BorderBrush="#7A5733">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Server Selection" />
                            <TextBlock x:Name="txtHelper"
                                       Margin="0,8,0,24"
                                       Style="{StaticResource BodyStyle}" />

                            <TextBlock Text="Available servers" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox x:Name="cbxServers"
                                      IsEditable="False"
                                      Style="{StaticResource InputComboBoxStyle}"
                                      SelectionChanged="CbxServers_SelectedIndexChanged" />

                            <Border Margin="0,20,0,0"
                                    Padding="18"
                                    Background="#2A1816"
                                    BorderBrush="#6B4C2D"
                                    BorderThickness="1"
                                    CornerRadius="22">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="Server status hint" />
                                    <TextBlock x:Name="txtLaunchTip"
                                               Margin="0,8,0,0"
                                               Style="{StaticResource BodyStyle}"
                                               Text="Choose a server first so the launch options stay in sync." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource CardBorderStyle}"
                            Background="#5A110D10"
                            BorderBrush="#8C6335">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="24" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="24" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource GoldBrush}"
                                           Text="READY TO ENTER" />
                                <TextBlock Margin="0,12,0,0"
                                           HorizontalAlignment="Center"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="Launch Client"
                                           TextAlignment="Center" />
                            </StackPanel>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Launch status" Style="{StaticResource FieldLabelStyle}" />
                                    <DockPanel Margin="0,10,0,0" LastChildFill="False">
                                        <Border x:Name="serverStatusBadge"
                                                Width="110"
                                                Height="38"
                                                Background="#6B4C2D"
                                                CornerRadius="19">
                                            <TextBlock x:Name="serverStatus"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       Text="-" />
                                        </Border>
                                        <TextBlock x:Name="txtProgressValue"
                                                   Margin="14,8,0,0"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Text="0%" />
                                    </DockPanel>
                                    <ProgressBar x:Name="pBar"
                                                 Margin="0,14,0,0"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Style="{StaticResource ProgressStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Resolution" Style="{StaticResource FieldLabelStyle}" />
                                    <ComboBox x:Name="cbxResolutions"
                                              Style="{StaticResource InputComboBoxStyle}"
                                              SelectionChanged="CbxResolutions_SelectedIndexChanged">
                                        <sys:String>800x600</sys:String>
                                        <sys:String>1024x768</sys:String>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="4" HorizontalAlignment="Center">
                                <Button x:Name="btnStart"
                                        Width="320"
                                        Height="66"
                                        Click="BtnStart_Click"
                                        Content="ENTER"
                                        Style="{StaticResource LaunchButtonStyle}" />
                                <TextBlock Margin="0,14,0,0"
                                           HorizontalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="The launcher saves your selected server and resolution automatically." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="4">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Guided Actions" />
                                <TextBlock x:Name="txtActionsDescription"
                                           Margin="0,8,0,0"
                                           Style="{StaticResource BodyStyle}"
                                           Text="Use settings for deeper configuration, or stay here for the normal launch flow." />

                                <Button x:Name="btnSettings"
                                        Margin="0,22,0,0"
                                        Click="BtnSettings_Click"
                                        Content="Open Settings"
                                        Style="{StaticResource SecondaryButtonStyle}" />

                                <Button x:Name="btnCreateServer"
                                        Margin="0,12,0,0"
                                        Click="BtnCreateServer_Click"
                                        Content="Create First Server"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Visibility="Collapsed" />

                                <CheckBox x:Name="tglAdvancedMode"
                                          Margin="0,18,0,0"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          Checked="TglAdvancedMode_CheckedChanged"
                                          Unchecked="TglAdvancedMode_CheckedChanged"
                                          Content="Show advanced options" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="advancedOptionsCard"
                                Margin="0,20,0,0"
                                Style="{StaticResource CardBorderStyle}"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Advanced" />
                                <TextBlock x:Name="txtAdvancedDescription"
                                           Margin="0,8,0,0"
                                           Style="{StaticResource BodyStyle}"
                                           Text="These options are useful for diagnostics and compatibility changes." />

                                <Border Margin="0,18,0,0"
                                        Padding="18"
                                        Background="#231719"
                                        BorderBrush="#6B4C2D"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock x:Name="lblFPSUnlock"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Style="{StaticResource BodyStyle}"
                                                       Text="Use this only when your client and server support it." />
                                        </StackPanel>

                                        <CheckBox x:Name="tglFPSUnlock"
                                                  Grid.Column="1"
                                                  Margin="18,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                  Content="Enabled"
                                                  Checked="TglFPSUnlock_CheckedChanged"
                                                  Unchecked="TglFPSUnlock_CheckedChanged" />
                                    </Grid>
                                </Border>

                                <Button x:Name="btnLogModules"
                                        Margin="0,18,0,0"
                                        Click="BtnLogModules_Click"
                                        Content="Log Modules"
                                        Style="{StaticResource SecondaryButtonStyle}" />

                                <Button x:Name="btnCloseCO"
                                        Margin="0,12,0,0"
                                        Click="BtnCloseCO_Click"
                                        Content="Close Game Process"
                                        Style="{StaticResource DangerButtonStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,20,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Quick Guide" />
                                <TextBlock x:Name="txtGuideLine1"
                                           Margin="0,18,0,0"
                                           Style="{StaticResource BodyStyle}"
                                           Text="1. Create or choose a server." />
                                <TextBlock x:Name="txtGuideLine2"
                                           Margin="0,8,0,0"
                                           Style="{StaticResource BodyStyle}"
                                           Text="2. Pick the resolution that matches your client." />
                                <TextBlock x:Name="txtGuideLine3"
                                           Margin="0,8,0,0"
                                           Style="{StaticResource BodyStyle}"
                                           Text="3. Press Enter when the setup looks correct." />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Grid x:Name="firstRunOverlay"
              Grid.RowSpan="2"
              Background="#CC040203"
              Visibility="Collapsed">
            <Grid Margin="24">
                <Border MaxWidth="760"
                        Padding="34"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#161014"
                        BorderBrush="#6B4C2D"
                        BorderThickness="1"
                        CornerRadius="30">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <Border Width="156"
                                    Height="34"
                                    Padding="12,6"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource PrimarySoftBrush}"
                                    CornerRadius="17">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           Text="First-time setup" />
                            </Border>

                            <TextBlock x:Name="txtFirstRunTitle"
                                       Margin="0,18,0,0"
                                       FontSize="34"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="Let's create your first server"
                                       TextWrapping="Wrap" />

                            <TextBlock x:Name="txtFirstRunDescription"
                                       Margin="0,14,0,0"
                                       FontSize="15"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="ConquerLoader needs at least one server before it can launch the game. The guided wizard will walk you through the setup step by step."
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Grid.Row="2"
                                Padding="20"
                                Background="#211517"
                                BorderBrush="#6B4C2D"
                                BorderThickness="1"
                                CornerRadius="22">
                            <StackPanel>
                                <TextBlock x:Name="txtFirstRunStep1"
                                           FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="1. Choose a name for the server so you can recognize it later."
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="txtFirstRunStep2"
                                           Margin="0,10,0,0"
                                           FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="2. Enter the server IP, client version, and executable in the wizard."
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="txtFirstRunStep3"
                                           Margin="0,10,0,0"
                                           FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="3. Save the server and come back here to launch the game."
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <WrapPanel Grid.Row="4"
                                   HorizontalAlignment="Left">
                            <Button x:Name="btnStartFirstRun"
                                    Width="220"
                                    Margin="0,0,12,12"
                                    Click="BtnStartFirstRun_Click"
                                    Content="Create My First Server"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Button x:Name="btnOpenSettingsFromOverlay"
                                    Width="170"
                                    Margin="0,0,12,12"
                                    Click="BtnSettings_Click"
                                    Content="Open Settings"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button x:Name="btnAboutFromOverlay"
                                    Width="110"
                                    Margin="0,0,0,12"
                                    Click="LblAbout_Click"
                                    Content="About"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
    </Grid>
    </Border>
</Window>
