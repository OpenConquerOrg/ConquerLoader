<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="SharedScrollTrackBrush" Color="#130D0E" />
    <SolidColorBrush x:Key="SharedScrollTrackBorderBrush" Color="#4B3324" />
    <SolidColorBrush x:Key="SharedScrollThumbBrush" Color="#873225" />
    <SolidColorBrush x:Key="SharedScrollThumbHoverBrush" Color="#AA402E" />
    <SolidColorBrush x:Key="SharedScrollThumbDragBrush" Color="#CB4E37" />
    <SolidColorBrush x:Key="SharedScrollThumbBorderBrush" Color="#D8A86A" />
    <SolidColorBrush x:Key="SharedScrollThumbHoverBorderBrush" Color="#F0C58D" />

    <Style x:Key="SharedScrollBarPageButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SharedScrollBarThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border x:Name="ThumbBorder"
                            Margin="2"
                            Background="{StaticResource SharedScrollThumbBrush}"
                            BorderBrush="{StaticResource SharedScrollThumbBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5">
                        <Border Margin="1"
                                Background="#22FFFFFF"
                                CornerRadius="4"
                                Opacity="0.16" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource SharedScrollThumbHoverBrush}" />
                            <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="{StaticResource SharedScrollThumbHoverBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource SharedScrollThumbDragBrush}" />
                            <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="#FFE0B36D" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="SharedVerticalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Width="{TemplateBinding Width}"
              Margin="0,4,0,4"
              Background="Transparent">
            <Border Margin="2,0"
                    Background="{StaticResource SharedScrollTrackBrush}"
                    BorderBrush="{StaticResource SharedScrollTrackBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="5" />
            <Track x:Name="PART_Track"
                   Focusable="False"
                   IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                  Style="{StaticResource SharedScrollBarPageButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource SharedScrollBarThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                  Style="{StaticResource SharedScrollBarPageButtonStyle}" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="SharedHorizontalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Height="{TemplateBinding Height}"
              Margin="4,0,4,0"
              Background="Transparent">
            <Border Margin="0,2"
                    Background="{StaticResource SharedScrollTrackBrush}"
                    BorderBrush="{StaticResource SharedScrollTrackBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="5" />
            <Track x:Name="PART_Track"
                   Focusable="False">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageLeftCommand"
                                  Style="{StaticResource SharedScrollBarPageButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource SharedScrollBarThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageRightCommand"
                                  Style="{StaticResource SharedScrollBarPageButtonStyle}" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template" Value="{StaticResource SharedVerticalScrollBarTemplate}" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Template" Value="{StaticResource SharedHorizontalScrollBarTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
