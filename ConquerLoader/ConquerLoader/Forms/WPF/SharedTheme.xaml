<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="SharedScrollPageButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SharedScrollThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="#C94029" />
        <Setter Property="BorderBrush" Value="#F4C7BE" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border x:Name="ThumbBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#E25239" />
                            <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="#FFE3DD" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#A12718" />
                            <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="#FFD6CD" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="SharedVerticalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Width="{TemplateBinding Width}"
              Margin="{TemplateBinding Margin}"
              Background="Transparent">
            <Border Margin="1,0,1,0"
                    Background="#64151A20"
                    BorderBrush="#7A5151"
                    BorderThickness="1"
                    CornerRadius="6" />
            <Track x:Name="PART_Track"
                   Margin="1,0,1,0"
                   Focusable="False"
                   ViewportSize="NaN"
                   IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                  Style="{StaticResource SharedScrollPageButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Height="68"
                           Style="{StaticResource SharedScrollThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                  Style="{StaticResource SharedScrollPageButtonStyle}" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="SharedHorizontalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Height="{TemplateBinding Height}"
              Margin="{TemplateBinding Margin}"
              Background="Transparent">
            <Border Margin="0,1,0,1"
                    Background="#64151A20"
                    BorderBrush="#7A5151"
                    BorderThickness="1"
                    CornerRadius="6" />
            <Track x:Name="PART_Track"
                   Margin="0,1,0,1"
                   Focusable="False">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageLeftCommand"
                                  Style="{StaticResource SharedScrollPageButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb MinWidth="56"
                           Style="{StaticResource SharedScrollThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageRightCommand"
                                  Style="{StaticResource SharedScrollPageButtonStyle}" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template" Value="{StaticResource SharedVerticalScrollBarTemplate}" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Height" Value="16" />
                <Setter Property="Margin" Value="0,4,0,0" />
                <Setter Property="Template" Value="{StaticResource SharedHorizontalScrollBarTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="#F4F7FC" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Border Background="Transparent">
                        <BulletDecorator VerticalAlignment="Center">
                            <BulletDecorator.Bullet>
                                <Border x:Name="CheckBorder"
                                        Width="22"
                                        Height="22"
                                        Margin="0,0,2,0"
                                        Background="#1A1218"
                                        BorderBrush="#9EA6B4"
                                        BorderThickness="1"
                                        CornerRadius="7">
                                    <Path x:Name="CheckGlyph"
                                          Width="11"
                                          Height="8"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Data="M 1 4.5 L 4.3 7.5 L 10 1"
                                          Stroke="White"
                                          StrokeThickness="2"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          Visibility="Collapsed" />
                                </Border>
                            </BulletDecorator.Bullet>
                            <TextBlock Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{TemplateBinding Content}"
                                       TextWrapping="WrapWithOverflow" />
                        </BulletDecorator>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CheckBorder" Property="Background" Value="#22151D" />
                            <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#C8CFDA" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#E2E8F0" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckBorder" Property="Background" Value="#A52F20" />
                            <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#F5A49A" />
                            <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="CheckBorder" Property="Background" Value="#C93A28" />
                            <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#FFD6D0" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
